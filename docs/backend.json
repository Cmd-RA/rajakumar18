
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account and their personal channel.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "isAdmin"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "Represents a photo post.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "photoUrl": { "type": "string" },
        "caption": { "type": "string" },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "photoUrl", "caption", "likesCount", "createdAt"]
    },
    "Complaint": {
      "title": "Complaint",
      "type": "object",
      "description": "User submitted support requests or complaints.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "username", "message", "status", "createdAt"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "type": "object",
      "description": "Global site configurations like AdSense code, Meta tags, and Live Stream links.",
      "properties": {
        "adsenseCode": { "type": "string", "description": "The script or meta tag provided by Google AdSense." },
        "liveVideoUrl": { "type": "string", "description": "The URL for the featured live video stream." },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Public user profiles."
        }
      },
      {
        "path": "/posts/{postId}",
        "definition": {
          "entityName": "Post",
          "description": "Public photo posts."
        }
      },
      {
        "path": "/complaints/{complaintId}",
        "definition": {
          "entityName": "Complaint",
          "description": "User support requests."
        }
      },
      {
        "path": "/settings/site_config",
        "definition": {
          "entityName": "SiteSettings",
          "description": "Global settings for SEO, AdSense, and Live Stream. Only admin can write."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Admin role assignment collection."
        }
      }
    ]
  }
}
